rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.uid in ['KffhYOBycQggcxA6ROXbed43Nav1'];
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdminOrMod() {
      return isSuperAdmin() || hasRole('admin') || hasRole('mod');
    }

    function isNotBanned() {
      return isAuthenticated() && getUserData().banned != true;
    }

    // User-scoped data: only the owner can read/write
    match /users/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
      // Admin can read and update any user doc (for role/ban management)
      allow read, update: if isSuperAdmin();

      match /trades/{tradeId} {
        allow read, write: if isAuthenticated() && request.auth.uid == uid;
        allow read: if isSuperAdmin();
      }

      match /dailyJournal/{journalId} {
        allow read, write: if isAuthenticated() && request.auth.uid == uid;
      }

      match /settings/{settingId} {
        allow read, write: if isAuthenticated() && request.auth.uid == uid;
      }
    }

    // Admin: only specific UIDs can list all users
    match /users/{uid} {
      allow list: if isSuperAdmin();
    }

    // Shared trades: anyone can read, authenticated non-banned users can create
    match /shared_trades/{token} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBanned();
      allow update: if isAuthenticated();

      // Likes subcollection
      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuthenticated() && request.auth.uid == userId && isNotBanned();
      }

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && isNotBanned();
        allow delete: if isAuthenticated() && (
          request.auth.uid == resource.data.userId ||
          isAdminOrMod()
        );
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
