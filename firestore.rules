rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User-scoped data: only the owner can read/write
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /trades/{tradeId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
        allow read: if request.auth != null && request.auth.uid in ['KffhYOBycQggcxA6ROXbed43Nav1'];
      }

      match /dailyJournal/{journalId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /settings/{settingId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Admin: only specific UIDs can list all users
    match /users/{uid} {
      allow list: if request.auth != null && request.auth.uid in ['KffhYOBycQggcxA6ROXbed43Nav1'];
    }

    // Shared trades: anyone can read, only authenticated users can create
    match /shared_trades/{token} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
