rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.uid in ['KffhYOBycQggcxA6ROXbed43Nav1'];
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdminOrMod() {
      return isSuperAdmin() || hasRole('admin') || hasRole('mod');
    }

    function isNotBanned() {
      return isAuthenticated() && (
        isSuperAdmin() ||
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.banned != true
      );
    }

    // User-scoped data: only the owner can read/write
    match /users/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
      // Any authenticated user can read a user's profile (for profile page)
      allow get: if isAuthenticated();
      // Admin can read and update any user doc (for role/ban management)
      allow read, update: if isSuperAdmin();

      match /trades/{tradeId} {
        allow read, write: if isAuthenticated() && request.auth.uid == uid;
        allow read: if isSuperAdmin();
      }

      match /dailyJournal/{journalId} {
        allow read, write: if isAuthenticated() && request.auth.uid == uid;
      }

      match /settings/{settingId} {
        allow read, write: if isAuthenticated() && request.auth.uid == uid;
      }

      match /following/{followedUid} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == uid;
      }

      match /followers/{followerUid} {
        // Any authenticated user can read followers list (for profile page)
        allow read: if isAuthenticated();
        allow create, delete: if isAuthenticated() && request.auth.uid == followerUid;
      }
    }

    // Admin: only specific UIDs can list all users
    match /users/{uid} {
      allow list: if isSuperAdmin();
    }

    // Shared trades: anyone can read, authenticated non-banned users can create
    match /shared_trades/{token} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBanned();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        resource.data.ownerUid == request.auth.uid || isAdminOrMod()
      );

      // Likes subcollection
      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuthenticated() && request.auth.uid == userId && isNotBanned();
      }

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && isNotBanned();
        allow delete: if isAuthenticated() && (
          request.auth.uid == resource.data.userId ||
          isAdminOrMod()
        );
      }

      // Reports subcollection
      match /reports/{userId} {
        allow read: if isAuthenticated() && isAdminOrMod();
        allow create, update: if isAuthenticated() && request.auth.uid == userId && isNotBanned();
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
